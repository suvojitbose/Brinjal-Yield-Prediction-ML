      "source": [
        "def calc_ammi(df, trait):\n",
        "    pivot = df.pivot_table(index='GEN', columns='ENV', values=trait, aggfunc='mean')\n",
        "    grand_mean = pivot.values.mean()\n",
        "    gen_means = pivot.mean(axis=1).values.reshape(-1, 1)\n",
        "    env_means = pivot.mean(axis=0).values.reshape(1, -1)\n",
        "\n",
        "    # Calculate GxE Interaction Matrix\n",
        "    interaction = pivot.values - gen_means - env_means + grand_mean\n",
        "\n",
        "    # Singular Value Decomposition\n",
        "    U, S, Vt = svd(interaction, full_matrices=False)\n",
        "\n",
        "    # IPCA Scores\n",
        "    ipca1_g = U[:, 0] * np.sqrt(S[0])\n",
        "    ipca2_g = U[:, 1] * np.sqrt(S[1])\n",
        "    ipca1_e = Vt[0, :] * np.sqrt(S[0])\n",
        "    ipca2_e = Vt[1, :] * np.sqrt(S[1])\n",
        "\n",
        "    return ipca1_g, ipca2_g, ipca1_e, ipca2_e, pivot.index, pivot.columns\n",
        "\n",
        "traits_to_plot = [('FYP', 'Fruit Yield (kg)'), ('ASC', 'Ascorbic Acid'),\n",
        "                  ('AN', 'Anthocyanin'), ('FP', 'Total Phenols')]\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(16, 16))\n",
        "axes = axes.flatten()\n",
        "\n",
        "for i, (trait, title) in enumerate(traits_to_plot):\n",
        "    ax = axes[i]\n",
        "    ipca1_g, ipca2_g, ipca1_e, ipca2_e, gen_labels, env_labels = calc_ammi(df, trait)\n",
        "\n",
        "    # Plot Genotypes\n",
        "    ax.scatter(ipca1_g, ipca2_g, color='royalblue', alpha=0.7, label='Genotypes', s=50)\n",
        "    for j, txt in enumerate(gen_labels):\n",
        "        ax.text(ipca1_g[j]+0.01, ipca2_g[j]+0.01, f'G{txt}', fontsize=9, color='darkblue')\n",
        "\n",
        "    # Plot Environments\n",
        "    ax.scatter(ipca1_e, ipca2_e, color='red', marker='^', label='Environments', s=150)\n",
        "    for j, txt in enumerate(env_labels):\n",
        "        ax.text(ipca1_e[j]+0.02, ipca2_e[j]+0.02, f'ENV {txt}', fontsize=11, color='darkred', fontweight='bold')\n",
        "\n",
        "    ax.axhline(0, color='black', linestyle='--', linewidth=1)\n",
        "    ax.axvline(0, color='black', linestyle='--', linewidth=1)\n",
        "    ax.set_title(f'({chr(65+i)}) AMMI 2: {title}', fontweight='bold')\n",
        "    ax.set_xlabel('IPCA 1')\n",
        "    ax.set_ylabel('IPCA 2')\n",
        "    ax.grid(True, linestyle=':', alpha=0.6)\n",
        "    if i == 0: ax.legend()\n",
        "\n",
        "plt.suptitle('Fig. 3. Multi-Trait AMMI 2 Biplots for Interaction Variance', fontsize=22, fontweight='bold', y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.savefig('Fig3_AMMI2_Biplots.png', bbox_inches='tight')\n",
        "plt.show()"
