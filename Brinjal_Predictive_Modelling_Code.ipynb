      "source": [
        "### Fig S4: Regression Tree Analysis for Ideotype Selection\n",
        "\n",
        "This regression tree aims to identify key morphological traits influencing fruit yield (FYP), facilitating the selection of optimal genotypes."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "6de47643"
      },
      "source": [
        "X_morpho = df[morpho_traits]\n",
        "\n",
        "tree_model = DecisionTreeRegressor(\n",
        "    max_depth=3,\n",
        "    criterion='friedman_mse',\n",
        "    random_state=42\n",
        ")\n",
        "tree_model.fit(X_morpho, df['FYP'])\n",
        "\n",
        "# Plotting\n",
        "plt.figure(figsize=(20, 10))\n",
        "plot_tree(\n",
        "    tree_model,\n",
        "    feature_names=X_morpho.columns,\n",
        "    filled=True,\n",
        "    rounded=True,\n",
        "    fontsize=10,\n",
        "    precision=2,\n",
        "    proportion=False\n",
        ")\n",
        "\n",
        "plt.title('Fig S4. Regression Tree Analysis for Ideotype Selection', fontsize=18, fontweight='bold', pad=20)\n",
        "plt.savefig('FigS4_Regression_Tree_Final_V2.png', bbox_inches='tight', dpi=300)\n",
        "plt.show()"
      ],
      "execution_count": null,
      "outputs": []
