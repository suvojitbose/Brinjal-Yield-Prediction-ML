        "def calc_gge(df, trait):\n",
        "    pivot = df.pivot_table(index='GEN', columns='ENV', values=trait, aggfunc='mean')\n",
        "    env_means = pivot.mean(axis=0).values.reshape(1, -1)\n",
        "\n",
        "    # Environment-centered matrix\n",
        "    centered = pivot.values - env_means\n",
        "\n",
        "    # SVD\n",
        "    U, S, Vt = svd(centered, full_matrices=False)\n",
        "    pc1_g = U[:, 0] * np.sqrt(S[0])\n",
        "    pc2_g = U[:, 1] * np.sqrt(S[1])\n",
        "    pc1_e = Vt[0, :] * np.sqrt(S[0])\n",
        "    pc2_e = Vt[1, :] * np.sqrt(S[1])\n",
        "\n",
        "    return pc1_g, pc2_g, pc1_e, pc2_e, pivot.index, pivot.columns\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(16, 16))\n",
        "axes = axes.flatten()\n",
        "\n",
        "for i, (trait, title) in enumerate(traits_to_plot):\n",
        "    ax = axes[i]\n",
        "    pc1_g, pc2_g, pc1_e, pc2_e, gen_labels, env_labels = calc_gge(df, trait)\n",
        "\n",
        "    # Convex Hull for Genotypes\n",
        "    points = np.column_stack((pc1_g, pc2_g))\n",
        "    hull = ConvexHull(points)\n",
        "\n",
        "    ax.scatter(pc1_g, pc2_g, color='teal', alpha=0.6, s=50)\n",
        "    for simplex in hull.simplices:\n",
        "        ax.plot(points[simplex, 0], points[simplex, 1], 'k-', linewidth=1.5)\n",
        "\n",
        "    for j, txt in enumerate(gen_labels):\n",
        "        ax.text(pc1_g[j], pc2_g[j]+0.02, f'G{txt}', fontsize=9, color='darkslategray')\n",
        "\n",
        "    # Environment Vectors\n",
        "    for j, txt in enumerate(env_labels):\n",
        "        ax.arrow(0, 0, pc1_e[j], pc2_e[j], color='red', alpha=0.7,\n",
