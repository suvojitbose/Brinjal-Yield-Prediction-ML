        "# ---------------------------------------------------------\n",
        "# Cell: Regenerated Fig. 1 (Matching Original Manuscript Style)\n",
        "# ---------------------------------------------------------\n",
        "\n",
        "# Ensure data is aggregated and scaled similarly to R's default behavior\n",
        "df_mean = df.groupby('GEN')[all_traits].mean()\n",
        "\n",
        "# Scale by columns (traits) - This matches R's standard heatmaps\n",
        "df_scaled = df_mean.apply(lambda x: (x - x.mean()) / x.std(), axis=0)\n",
        "\n",
        "# Generate Hierarchical Clustering Heatmap\n",
        "# Using 'RdBu_r' (Red-Blue Reversed) to match the classic academic heatmap style\n",
        "g = sns.clustermap(\n",
        "    df_scaled,\n",
        "    cmap='RdBu_r',          # This color map is the standard for R-style heatmaps\n",
        "    method='complete',      # Matches R's hclust default\n",
        "    metric='euclidean',     # Matches R's dist default\n",
        "    figsize=(10, 10),\n",
        "    linewidths=0.5,         # Adds the distinct white grid lines\n",
        "    linecolor='white',\n",
        "    dendrogram_ratio=(0.15, 0.15),\n",
        "    tree_kws={'linewidth': 1.5},\n",
        "    cbar_kws={'label': 'Z-Score'}\n",
        ")\n",
        "\n",
        "# Formatting\n",
        "g.ax_heatmap.set_ylabel('Genotypes (1-25)', fontweight='bold', fontsize=12)\n",
        "g.ax_heatmap.set_xlabel('Morphological & Biochemical Traits', fontweight='bold', fontsize=12)\n",
        "g.ax_heatmap.yaxis.set_label_position(\"right\")\n",
        "\n",
        "# Title\n",
        "plt.suptitle('Fig. 1. Hierarchical Clustering Heatmap of Genotypic Diversity', fontweight='bold', y=1.02, fontsize=14)\n",
        "\n",
        "# Rotate labels to be readable\n",
        "plt.setp(g.ax_heatmap.get_xticklabels(), rotation=45, ha=\"right\", fontsize=10)\n",
        "plt.setp(g.ax_heatmap.get_yticklabels(), rotation=0, fontsize=10)\n",
        "\n",
        "# Save as high-resolution\n",
        "plt.savefig('Fig1_Hierarchical_Clustering_Final.png', bbox_inches='tight', dpi=300)\n",
        "plt.show()"
