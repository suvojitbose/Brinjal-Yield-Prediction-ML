      "source": [
        "# Aggregate by Genotype\n",
        "df_mean = df.groupby('GEN')[all_traits].mean()\n",
        "\n",
        "# Standardize the traits (Z-score)\n",
        "scaler = StandardScaler()\n",
        "df_scaled = pd.DataFrame(scaler.fit_transform(df_mean), columns=all_traits, index=df_mean.index)\n",
        "df_scaled.index = df_scaled.index.astype(str)\n",
        "\n",
        "# Generate Hierarchical Clustering Heatmap\n",
        "g = sns.clustermap(\n",
        "    df_scaled,\n",
        "    cmap='viridis',\n",
        "    method='ward',\n",
        "    metric='euclidean',\n",
        "    figsize=(12, 12),\n",
        "    cbar_pos=(0.02, 0.8, 0.05, 0.18),\n",
        "    linewidths=0.5,\n",
        "    dendrogram_ratio=(0.15, 0.15),\n",
        "    tree_kws={'linewidth': 1.5}\n",
        ")\n",
        "\n",
        "g.ax_heatmap.set_ylabel('Genotypes (1-25)', fontweight='bold', labelpad=15)\n",
        "g.ax_heatmap.set_xlabel('Morphological & Biochemical Traits', fontweight='bold', labelpad=15)\n",
        "g.ax_heatmap.yaxis.set_label_position(\"right\")\n",
        "\n",
        "plt.suptitle('Fig. 1. Hierarchical Clustering Heatmap of Genotypic Diversity', fontweight='bold', y=1.02)\n",
