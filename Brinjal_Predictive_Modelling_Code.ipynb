        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.model_selection import RepeatedKFold\n",
        "from sklearn.tree import DecisionTreeRegressor, plot_tree\n",
        "from sklearn.decomposition import PCA\n",
        "from scipy.linalg import svd\n",
        "from scipy.spatial import ConvexHull\n",
        "import networkx as nx\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# 1. Load Data\n",
        "file_path = \"/content/AMMI FINAL DATA (1).xlsx\" # Ensure this is uploaded to your Colab workspace\n",
        "xls = pd.ExcelFile(file_path)\n",
        "df = pd.read_excel(xls, sheet_name=0)\n",
        "df_sheet2 = pd.read_excel(xls, sheet_name=1)\n",
        "\n",
        "# Clean and Merge TSS\n",
        "df['TSS'] = pd.to_numeric(df_sheet2['TSS'], errors='coerce')\n",
        "df['TSS'].fillna(df['TSS'].mean(), inplace=True) # Handle any potential NaNs safely\n",
        "\n",
        "# 2. Define Traits\n",
        "morpho_traits = ['PH', 'PB', 'DF', 'FL', 'FD', 'FW', 'NFP']\n",
        "bio_traits = ['ASC', 'AN', 'FP', 'TSS']\n",
        "yield_trait = ['FYP']\n",
        "all_traits = morpho_traits + bio_traits + yield_trait\n",
        "\n",
        "# 3. Map Environmental Weather Data (from Table S1)\n",
        "weather_dict = {\n",
        "    1: {'Max_Temp': 29.49, 'Rainfall': 851.83, 'Humidity': 68.64},\n",
        "    2: {'Max_Temp': 31.97, 'Rainfall': 399.39, 'Humidity': 53.21},\n",
        "    3: {'Max_Temp': 32.19, 'Rainfall': 383.88, 'Humidity': 49.49}\n",
        "}\n",
        "df['Max_Temp'] = df['ENV'].map(lambda x: weather_dict[x]['Max_Temp'])\n",
        "df['Rainfall'] = df['ENV'].map(lambda x: weather_dict[x]['Rainfall'])\n",
        "df['Humidity'] = df['ENV'].map(lambda x: weather_dict[x]['Humidity'])\n",
        "\n",
        "# Global Plot Settings for Editorial Standards\n",
        "plt.rcParams.update({\n",
        "    'font.family': 'serif', # Use a serif font similar to Times New Roman\n",
        "    'font.serif': ['Times New Roman', 'DejaVu Serif', 'Computer Modern Roman'], # Specify Times New Roman or alternatives\n",
        "    'font.size': 15, # Increased from 14\n",
        "    'axes.labelsize': 17, # Increased from 16\n",
        "    'axes.titlesize': 19, # Increased from 18\n",
        "    'xtick.labelsize': 13, # Increased from 12\n",
        "    'ytick.labelsize': 13, # Increased from 12\n",
        "    'figure.titlesize': 21, # Increased from 20\n",
        "    'figure.dpi': 300\n",
        "})\n",
        "\n",
        "print(\"Data loaded and preprocessed successfully. Ready to generate figures.\")"
      ]
    },
