      "source": [
        "### Fig S2: Correlation Network Analysis of Trait Architecture\n",
        "\n",
        "A network graph mapping the phenotypic correlations (r > 0.20) among vegetative, biochemical, and physical yield traits in brinjal. Blue edges denote positive synergistic relationships, while red edges highlight negative biological trade-offs."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "94c27d3b"
      },
      "source": [
        "plt.figure(figsize=(12, 10))\n",
        "corr_matrix_net = df[all_traits].corr()\n",
        "\n",
        "G = nx.Graph()\n",
        "for col in corr_matrix_net.columns:\n",
        "    G.add_node(col)\n",
        "\n",
        "for i in range(len(corr_matrix_net.columns)):\n",
        "    for j in range(i+1, len(corr_matrix_net.columns)):\n",
        "        weight = corr_matrix_net.iloc[i, j]\n",
        "        if abs(weight) > 0.20:\n",
        "            G.add_edge(corr_matrix_net.columns[i], corr_matrix_net.columns[j], weight=weight)\n",
        "\n",
        "pos = nx.spring_layout(G, seed=42, k=0.5)\n",
        "edges = G.edges(data=True)\n",
        "\n",
        "pos_edges = [(u, v) for u, v, d in edges if d['weight'] > 0]\n",
        "neg_edges = [(u, v) for u, v, d in edges if d['weight'] < 0]\n",
        "\n",
        "nx.draw_networkx_nodes(G, pos, node_size=2500, node_color='gold', edgecolors='black', linewidths=1.5)\n",
        "nx.draw_networkx_edges(G, pos, edgelist=pos_edges, edge_color='royalblue', width=2, alpha=0.7)\n",
        "nx.draw_networkx_edges(G, pos, edgelist=neg_edges, edge_color='firebrick', width=2, alpha=0.7)\n",
        "nx.draw_networkx_labels(G, pos, font_size=12, font_weight='bold')\n",
        "\n",
        "plt.title(\"Fig S2. Correlation Network Analysis of Trait Architecture\", fontweight='bold')\n",
        "plt.axis('off')\n",
        "\n",
        "# Manual Legend\n",
        "import matplotlib.lines as mlines\n",
        "blue_line = mlines.Line2D([], [], color='royalblue', linewidth=2, label='Positive Correlation (r > 0.20)')\n",
        "red_line = mlines.Line2D([], [], color='firebrick', linewidth=2, label='Negative Correlation (r < -0.20)')\n",
        "plt.legend(handles=[blue_line, red_line], loc='upper right')\n",
        "\n",
        "plt.savefig('FigS2_Correlation_Network.png', bbox_inches='tight')\n",
        "plt.show()"
      ],
      "execution_count": null,
      "outputs": []
    },
