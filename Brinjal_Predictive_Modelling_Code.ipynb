        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.model_selection import RepeatedKFold\n",
        "from sklearn.tree import DecisionTreeRegressor, plot_tree\n",
        "from sklearn.decomposition import PCA\n",
        "from scipy.linalg import svd\n",
        "from scipy.spatial import ConvexHull\n",
        "import networkx as nx\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# 1. Load Data DIRECTLY from your GitHub repository\n",
        "# This bypasses Colab's temporary file system entirely!\n",
        "github_url = \"https://raw.githubusercontent.com/suvojitbose/Brinjal-Yield-Prediction-ML/main/AMMI%20FINAL%20DATA%20(1).xlsx\"\n",
        "xls = pd.ExcelFile(github_url)\n",
        "df = pd.read_excel(xls, sheet_name=0)\n",
        "df_sheet2 = pd.read_excel(xls, sheet_name=1)\n",
        "\n",
        "# Clean and Merge TSS\n",
        "df['TSS'] = pd.to_numeric(df_sheet2['TSS'], errors='coerce')\n",
        "df['TSS'].fillna(df['TSS'].mean(), inplace=True)\n",
        "\n",
        "# 2. Define Traits\n",
        "morpho_traits = ['PH', 'PB', 'DF', 'FL', 'FD', 'FW', 'NFP']\n",
